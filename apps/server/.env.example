# 部署时复制为 .env.production 并修改

NODE_ENV=production

# SQLite (默认，无需额外安装)
DATABASE_URL="file:./prod.db"

# PostgreSQL (生产推荐，需先安装PostgreSQL)
# DATABASE_URL="postgresql://user:password@localhost:5432/fortune_teller"

# JWT密钥 — 务必修改为随机字符串！
# 生成随机密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-to-a-random-string-at-least-32-chars"

# Token有效期
JWT_EXPIRES_IN="30d"

# 服务端口
PORT=3001

# CORS (生产环境设为你的域名)
CORS_ORIGIN="*"
