{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/client && npx vite build"
  },
  "deploy": {
    "startCommand": "cd apps/server && NODE_ENV=production npx tsx src/index.ts",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
